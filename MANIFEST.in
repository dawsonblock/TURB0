include README.md
include LICENSE
include turboquant/contract.json
# Python package sources ship via setuptools package discovery; the sdist also
# carries docs/*.md for contract and release review.
recursive-include mlx_lm py.typed
recursive-include docs *.md
prune tests
prune benchmarks
# Retained runtime-cert bundles are local evidence, not shipped package data.
prune artifacts

# Exclude caches and scratch files
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
exclude fix_*.py
exclude test_*.py
exclude inspect_mx.py
exclude Session
exclude *.code-workspace
